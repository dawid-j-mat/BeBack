# BeBack – environment variables template.
# Copy to .env.local and fill in real values. Never commit .env.local.
# Supabase values: dashboard -> Project Settings -> API.
# Google key: console.cloud.google.com -> APIs & Services -> Credentials
# (restricted to our domains and to Places API (New); see docs/google-places.md).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_PLACES_KEY=
# Place search provider: google | osm. Leave empty for the default (D-25):
# Google when the key above is set, the free OSM pair (Overpass + Photon)
# otherwise; OSM also kicks in automatically whenever Google fails.
VITE_PLACES_PROVIDER=
